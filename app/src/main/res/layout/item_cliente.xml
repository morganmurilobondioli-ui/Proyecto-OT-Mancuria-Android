<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/fondo_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Icono de tipo -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="@color/rojo_fondo"
            app:cardElevation="0dp"
            android:layout_marginEnd="14dp">
            <ImageView
                android:id="@+id/ivTipoCliente"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Datos del cliente -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvNombreCliente"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nombre del cliente"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_principal"/>
                <TextView
                    android:id="@+id/tvTipoBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Persona"
                    android:textSize="10sp"
                    android:textColor="@color/rojo_mancuria"
                    android:background="@drawable/bg_badge_estado"
                    android:backgroundTint="@color/rojo_fondo"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTelefonoCliente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin teléfono"
                android:textSize="13sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvVehiculosCliente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 vehículo(s)"
                android:textSize="12sp"
                android:textColor="@color/rojo_mancuria"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
