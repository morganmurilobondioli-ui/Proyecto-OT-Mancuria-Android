<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/InputRojo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Placa * (ej: ABC-123)"
        android:layout_marginBottom="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPlacaVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1C1B1F"
            android:inputType="textCapCharacters"
            android:maxLength="7"
            android:textAllCaps="true"/>
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/InputRojo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Marca"
            android:layout_marginEnd="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMarcaVehiculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1C1B1F"
                android:inputType="textCapWords"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/InputRojo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Modelo">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etModeloVehiculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1C1B1F"
                android:inputType="textCapWords"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/InputRojo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Año"
            android:layout_marginEnd="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAnioVehiculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1C1B1F"
                android:inputType="number"
                android:maxLength="4"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/InputRojo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Color">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etColorVehiculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1C1B1F"
                android:inputType="textCapWords"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/InputRojo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="VIN (Número de chasis) - 17 caracteres"
        android:layout_marginBottom="12dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etVinVehiculo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1C1B1F"
            android:inputType="textCapCharacters"
            android:maxLength="17"
            android:textAllCaps="true"/>
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
