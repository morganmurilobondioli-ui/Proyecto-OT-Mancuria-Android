<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_app">

    <!-- ═══════════════ TOP BAR ROJA ═══════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/rojo_mancuria"
        android:paddingBottom="14dp">

        <!-- Fila: foto + nombre + logout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="2dp">
                <ImageView
                    android:id="@+id/ivUserPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/ic_launcher_round"/>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bienvenido,"
                    android:textColor="#FFCCCC"
                    android:textSize="11sp"/>
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cargando..."
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Botón Clientes -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClientes"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Clientes"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                app:strokeColor="#FFFFFF"
                app:cornerRadius="18dp"
                android:layout_marginEnd="6dp"/>

            <ImageButton
                android:id="@+id/btnLogout"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_lock_power_off"
                android:tint="#FFFFFF"
                android:contentDescription="Cerrar sesión"/>
        </LinearLayout>

        <!-- Buscador -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="4dp"
            android:hint="Buscar por placa o cliente..."
            app:boxStrokeColor="#FFFFFF"
            app:boxBackgroundColor="#33FFFFFF"
            app:hintTextColor="#FFFFFF"
            app:boxCornerRadiusTopStart="28dp"
            app:boxCornerRadiusTopEnd="28dp"
            app:boxCornerRadiusBottomStart="28dp"
            app:boxCornerRadiusBottomEnd="28dp"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="#FFFFFF">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBuscador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textColorHint="#BBBBBB"
                android:inputType="text"
                android:imeOptions="actionSearch"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- ═══════════════ CONTENIDO SCROLLEABLE ═══════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header de la lista -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@color/rojo_mancuria"
                    android:layout_marginEnd="10dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Órdenes Activas"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_principal"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNuevaOrden"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="+ Nueva Orden"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    app:backgroundTint="@color/rojo_mancuria"
                    app:cornerRadius="18dp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOrdenes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
