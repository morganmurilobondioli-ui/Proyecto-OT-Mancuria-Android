<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp"
    android:paddingTop="48dp"
    android:background="@drawable/bg_login">

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Logo con contenedor PRO -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="96dp"
        android:layout_height="96dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FFFFFF">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_logo"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mancuria"
        android:textSize="26sp"
        android:textColor="#202124"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="16dp"/>

    <!-- Línea decorativa -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#db2d2c"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"/>

    <!-- Subtítulo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/inicia_sesi_n_para_continuar"
        android:textSize="14sp"
        android:textColor="#5F6368"
        android:layout_marginBottom="32dp"/>

    <!-- Botón Google PRO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogleLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Continuar con Google"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="#202124"
        android:gravity="center_vertical"
        app:cornerRadius="28dp"
        app:backgroundTint="#FFFFFF"
        app:strokeColor="#db2d2c"
        app:strokeWidth="1dp"
        app:icon="@drawable/google_icon_1"
        app:iconTint="@null"
        app:iconSize="18dp"
        app:iconPadding="16dp"
        app:iconGravity="textStart"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2" />

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Versión 2.0"
        android:textSize="12sp"
        android:textColor="#9AA0A6"/>

</LinearLayout>