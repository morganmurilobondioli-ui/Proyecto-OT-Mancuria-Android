<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/fondo_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Fila 1: Placa + Badge estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/tvPlacaItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ABC-123"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/rojo_mancuria"/>

            <TextView
                android:id="@+id/tvEstadoItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendiente"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_badge_estado"
                android:backgroundTint="@color/badge_pendiente"/>
        </LinearLayout>

        <!-- Fila 2: Cliente -->
        <TextView
            android:id="@+id/tvClienteItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del Cliente"
            android:textSize="14sp"
            android:textColor="@color/texto_principal"
            android:layout_marginBottom="2dp"/>

        <!-- Fila 3: Vehículo/modelo -->
        <TextView
            android:id="@+id/tvModeloItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toyota Corolla 2020"
            android:textSize="13sp"
            android:textColor="@color/texto_secundario"
            android:layout_marginBottom="6dp"/>

        <!-- Fila Falla Reportada -->
        <LinearLayout
            android:id="@+id/layoutFallaItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:alpha="0.8">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/rojo_mancuria"/>
            <TextView
                android:id="@+id/tvFallaItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descripción de la falla reportada..."
                android:textSize="12sp"
                android:textColor="@color/texto_principal"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="10dp"/>

        <!-- Fila 4: Fecha + Km + Monto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvFechaItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="23/03/2026"
                android:textSize="12sp"
                android:textColor="@color/texto_secundario"
                android:drawableStart="@android:drawable/ic_menu_today"
                android:drawablePadding="4dp"
                android:drawableTint="@color/texto_secundario"/>

            <TextView
                android:id="@+id/tvKilometrajeItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45,000 km"
                android:textSize="12sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/tvMontoItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/texto_principal"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
